# ─────────────────────────────────────────────────────────────────────────────
# SETUP: Copy this file to backend/.env (same folder as server.js)
#        Fill in SMTP_USER and SMTP_PASS with your Gmail credentials.
#
# Gmail App Password:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail" / "Other (Portfolio)"
#   4. Paste the 16-character password into SMTP_PASS (no spaces)
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
# Use 465 (SSL) — works on most networks. Port 587 is often blocked by ISPs/college WiFi.
SMTP_PORT=465
# Optional: set to true when using port 465 (auto-detected if omitted)
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=kusheendhar@gmail.com
PORT=5000

# Comma-separated origins allowed for CORS (production + local dev)
FRONTEND_URL=http://localhost:5173,http://localhost:4173

# Optional: enable verbose contact/email logs (default on when NODE_ENV != production)
DEBUG_CONTACT=true
